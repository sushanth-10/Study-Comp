{
    "name": "scholarly-frontend",
    "buildCommand": "echo 'No build needed for vanilla JS'",
    "outputDirectory": ".",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        }
    ],
    "env": {
        "VITE_API_URL": "@vercel-api-url"
    }
}