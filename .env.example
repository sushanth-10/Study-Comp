# Copy to .env and fill in your real values (never commit .env)
SECRET_KEY=change-me-for-production
DATABASE_URL=sqlite:///scholarly.db

# Optional legacy OpenAI fallbacks used by ai_service.py and quiz_service.py
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter adaptive AI engine
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=Scholarly

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
